# ──────────────────────────────────────────────
# Studio Environment Variables
# ──────────────────────────────────────────────
# Copy from .env.example and fill in real values.
# NEVER commit this file to git.
# ──────────────────────────────────────────────

# ─── AI / LLM ────────────────────────────────

# Anthropic — Claude API (primary LLM)
ANTHROPIC_API_KEY=

# OpenAI — DALL-E 3 image generation (ambassador headshots, product mockups)
OPENAI_API_KEY=

# ─── Content Creation ─────────────────────────

# ElevenLabs — text-to-speech, voice cloning, music/SFX generation
ELEVENLABS_API_KEY=

# ElevenLabs voice IDs
ELEVENLABS_VOICE_ID_PINK=           # Pink's voice
ELEVENLABS_VOICE_ID_ALBINO_PINK=    # Troy's cloned voice (Albino Pink project)

# HeyGen — AI avatar video generation (Agape 26 ambassadors)
HEYGEN_API_KEY=

# Remove.bg — background removal for ambassador images
REMOVEBG_API_KEY=

# ─── Pink Pineapple — Backend ─────────────────

# MongoDB connection string (Prisma)
PP_MONGODB_URL=

# JWT secrets (generate 64-char random strings)
PP_JWT_SECRET=
PP_REFRESH_TOKEN_SECRET=
PP_RESET_PASS_TOKEN=

# Stripe — payment processing
PP_STRIPE_SECRET_KEY=
PP_STRIPE_PUBLISHABLE_KEY=

# DigitalOcean Spaces — file/image storage
PP_DO_SPACES_KEY=
PP_DO_SPACES_SECRET=
PP_DO_SPACES_ENDPOINT=
PP_DO_SPACES_BUCKET=

# Cloudinary — image CDN and processing
PP_CLOUDINARY_CLOUD_NAME=
PP_CLOUDINARY_API_KEY=
PP_CLOUDINARY_API_SECRET=

# Firebase — push notifications (needs NEW project, not mawaddah-match)
PP_FIREBASE_PROJECT_ID=
PP_FIREBASE_PRIVATE_KEY=
PP_FIREBASE_CLIENT_EMAIL=

# Gmail — transactional email (OTP, password reset)
PP_GMAIL_USER=
PP_GMAIL_APP_PASSWORD=

# ─── Agape 26 ────────────────────────────────

# GoDaddy — domain management (agape26.com)
# No API key needed unless automating DNS

# Cloudflare — CDN for agape26.com
# Managed via Frankie's VPS, no key needed locally

# ─── Telegram ─────────────────────────────────

# Frankie's Telegram bot token
TELEGRAM_BOT_TOKEN=

# ─── Agent Gateways ───────────────────────────

# Frankie gateway (cloud VPS — for agent-to-agent communication)
FRANKIE_GATEWAY_URL=https://frankie.agape26.com/v1/chat/completions
FRANKIE_GATEWAY_TOKEN=

# Pink gateway (local MacBook)
PINK_GATEWAY_URL=https://pink.agape26.com/v1/chat/completions
PINK_GATEWAY_TOKEN=
