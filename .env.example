# ──────────────────────────────────────────────
# Studio Environment Variables
# ──────────────────────────────────────────────
# Copy from .env.example and fill in real values.
# NEVER commit this file to git.
# ──────────────────────────────────────────────

# ─── AI / LLM ────────────────────────────────

ANTHROPIC_API_KEY=YOUR_KEY_HERE              # Claude API — primary LLM for Claude Code and agent workflows
OPENAI_API_KEY=YOUR_KEY_HERE                 # OpenAI — DALL-E 3 image generation, GPT-image-1 product mockups
GEMINI_API_KEY=YOUR_KEY_HERE                 # Google Gemini — embedding model for memory search

# ─── Content Creation ─────────────────────────

ELEVENLABS_API_KEY=YOUR_KEY_HERE             # ElevenLabs — text-to-speech, voice cloning, music/SFX
HEYGEN_API_KEY=YOUR_KEY_HERE                 # HeyGen — AI avatar video generation (Agape 26 ambassadors)
REMOVE_BG_API_KEY=YOUR_KEY_HERE              # Remove.bg — background removal for ambassador headshots

# ─── Messaging ────────────────────────────────

TELEGRAM_BOT_TOKEN=YOUR_KEY_HERE             # Telegram bot token for Frankie/Pink agent communication
TELEGRAM_BOT_TOKEN_TROY=YOUR_KEY_HERE        # Troy's bot (@pinkalbinobot) — local MacBook agent
TELEGRAM_ALLOWED_USER_IDS=YOUR_KEY_HERE      # Comma-separated Telegram user IDs allowed to message the bot

# ─── Pink Pineapple — Backend ─────────────────
# ROTATE BEFORE HANDOVER FROM FIVERR
# These credentials were exposed in the Fiverr-delivered repo.
# Generate new values before going to production.

MONGODB_URI=YOUR_KEY_HERE                    # MongoDB connection string (Prisma) — ROTATE BEFORE HANDOVER FROM FIVERR
DIGITALOCEAN_SPACES_KEY=YOUR_KEY_HERE        # DigitalOcean Spaces access key — ROTATE BEFORE HANDOVER FROM FIVERR
DIGITALOCEAN_SPACES_SECRET=YOUR_KEY_HERE     # DigitalOcean Spaces secret key — ROTATE BEFORE HANDOVER FROM FIVERR
CLOUDINARY_API_KEY=YOUR_KEY_HERE             # Cloudinary image CDN — ROTATE BEFORE HANDOVER FROM FIVERR
CLOUDINARY_API_SECRET=YOUR_KEY_HERE          # Cloudinary secret — ROTATE BEFORE HANDOVER FROM FIVERR
GMAIL_APP_PASSWORD=YOUR_KEY_HERE             # Gmail app password for OTP/transactional email — ROTATE BEFORE HANDOVER FROM FIVERR
FIREBASE_PROJECT_ID=YOUR_KEY_HERE            # Firebase project for push notifications (create NEW project, not mawaddah-match) — ROTATE BEFORE HANDOVER FROM FIVERR

# ─── Payments ─────────────────────────────────

STRIPE_PUBLIC_KEY=YOUR_KEY_HERE              # Stripe publishable key — client-side checkout
STRIPE_SECRET_KEY=YOUR_KEY_HERE              # Stripe secret key — server-side payment processing
