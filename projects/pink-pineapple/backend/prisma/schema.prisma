generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id                 String               @id @default(auto()) @map("_id") @db.ObjectId
  fullName           String
  email              String               @unique
  username           String               @default("")
  dob                DateTime             @default(now())
  profilePrivacy     ProfilePrivacyStatus @default(VIEWABLE)
  fullAddress        String               @default("")
  country            String               @default("")
  city               String               @default("")
  instagram          String               @default("")
  gender             String               @default("")
  bio                String               @default("")
  phoneNumber        String
  typeOfVenue        String               @default("")
  taxId              String               @default("")
  businessLicense    String ?              @default("")
  profileImage       String               @default("")
  expirationOtp      DateTime?
  otp                Int?
  password           String?
  isApproved         Boolean              @default(false)
  isCompleteProfile  Boolean              @default(false)
  fcmToken           String?
  role               UserRole             @default(USER)
  status             UserStatus           @default(INACTIVE)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  receiver           Notification[]       @relation("Receiver")
  sender             Notification[]       @relation("Sender")
  post               Post[]
  like               Like[]
  comment            Comment[]
  followers          Follower[]           @relation("FollowedUsers")
  following          Follower[]           @relation("FollowingUsers")
  clubAvailableDays  ClubAvailableDays[]  @relation("Club")
  clubAvailableTimes ClubAvailableTimes[] @relation("Club")
  clubFavorite       ClubFavorite[]       @relation("club")
  userFavorite       ClubFavorite[]       @relation("user")
  eventFavorite      EventFavorite[]
  booking            Booking[]
  FavoritePost       FavoritePost[]
  roomsSent          Room[]               @relation("SenderRelation")
  roomsReceived      Room[]               @relation("ReceiverRelation")
  chatsSent          Chat[]               @relation("SenderRelation")
  chatsReceived      Chat[]               @relation("ReceiverRelation")
  Events             Events[]
  venues             Venue[]          @relation("VenueOwner")
  venueFavorites     VenueFavorite[]  @relation("VenueFavorites")
  venueRatings       VenueRating[]
  venueVibes         VenueVibe[]
  venueBookingClicks VenueBookingClick[] @relation("UserBookingClicks")

  blocker   BlockUser[] @relation("blocker")
  blocked   BlockUser[] @relation("blocked")


  @@map("users")
}

model Notification {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  receiverId String   @db.ObjectId
  senderId   String   @db.ObjectId
  receiver   User     @relation("Receiver", fields: [receiverId], references: [id])
  sender     User     @relation("Sender", fields: [senderId], references: [id])
  title      String
  body       String
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("notifications")
}

model Post {
  id           String         @id @default(auto()) @map("_id") @db.ObjectId
  text         String?
  photos       Json?
  videos       Json?
  isHidden     Boolean        @default(false)
  likeCount    Int?           @default(0)
  userId       String         @db.ObjectId
  user         User           @relation(fields: [userId], references: [id])
  likes        Like[]         @relation("PostLikes")
  comments     Comment[]      @relation("PostComments")
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  FavoritePost FavoritePost[]

  @@map("posts")
}

model Like {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  postId    String   @db.ObjectId
  post      Post     @relation("PostLikes", fields: [postId], references: [id])
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@map("likes")
}

model Comment {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  text      String
  userId    String   @db.ObjectId
  postId    String   @db.ObjectId
  post      Post     @relation("PostComments", fields: [postId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])

  @@map("comments")
}

model Follower {
  id          String         @id @default(auto()) @map("_id") @db.ObjectId
  followerId  String         @db.ObjectId
  follower    User           @relation("FollowingUsers", fields: [followerId], references: [id])
  followingId String         @db.ObjectId
  following   User           @relation("FollowedUsers", fields: [followingId], references: [id])
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  status      FollowerStatus @default(PENDING)

  @@map("followers")
}

model AvailableDays {
  id                String              @id @default(auto()) @map("_id") @db.ObjectId
  day               String
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  clubAvailableDays ClubAvailableDays[] @relation("availableDays")
}

model AvailableTime {
  id                 String               @id @default(auto()) @map("_id") @db.ObjectId
  time               String
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  clubAvailableTimes ClubAvailableTimes[] @relation("availableTimes")
}

model ClubAvailableDays {
  id              String        @id @default(auto()) @map("_id") @db.ObjectId
  clubId          String        @db.ObjectId
  club            User          @relation("Club", fields: [clubId], references: [id])
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  availableDaysId String        @db.ObjectId
  availableDays   AvailableDays @relation("availableDays", fields: [availableDaysId], references: [id])
}

model ClubAvailableTimes {
  id               String        @id @default(auto()) @map("_id") @db.ObjectId
  clubId           String        @db.ObjectId
  club             User          @relation("Club", fields: [clubId], references: [id])
  availableTimesId String        @db.ObjectId
  availableTimes   AvailableTime @relation("availableTimes", fields: [availableTimesId], references: [id])
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}

model Events {
  id                String          @id @default(auto()) @map("_id") @db.ObjectId
  eventName         String
  descriptions      String
  startDate         DateTime
  endDate           DateTime
  startTime         String
  endTime           String
  lastRegDate       DateTime
  lastRegTime       String
  arriveDate        DateTime
  arriveTime        String
  additionalGuests  Int
  extraRequirements String
  userId            String          @db.ObjectId
  user              User            @relation(fields: [userId], references: [id])
  venueId           String?         @db.ObjectId
  venue             Venue?          @relation("VenueEvents", fields: [venueId], references: [id])
  eventImages       String[]
  eventStatus       EventStatus     @default(PENDING)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  eventTickets      EventTickets[]
  eventTable        EventTable[]
  eventFavorite     EventFavorite[]
  booking           Booking[]
}

model EventTickets {
  id               String          @id @default(auto()) @map("_id") @db.ObjectId
  maleAdmission    Int
  femaleAdmission  Int
  ticketLimitation Int
  eventId          String          @db.ObjectId
  event            Events          @relation(fields: [eventId], references: [id])
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  ticketCharges    TicketCharges[]
  booking          Booking[]
}

model TicketCharges {
  id            String       @id @default(auto()) @map("_id") @db.ObjectId
  feeName       String
  // TODO: Should be Float — stored as String by Fiverr team. Fix during data migration.
  feeAmount     String
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  eventTicketId String       @db.ObjectId
  eventTicket   EventTickets @relation(fields: [eventTicketId], references: [id])
}

model EventTable {
  id                     String         @id @default(auto()) @map("_id") @db.ObjectId
  tableName              String
  tableDetails           String
  maxAdditionGuest       Int
  minimumSpentAmount     Int
  isIncludedFoodBeverage Boolean
  tableImages            String[]
  eventId                String         @db.ObjectId
  event                  Events         @relation(fields: [eventId], references: [id])
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt
  tableCharges           TableCharges[]
  booking                Booking[]
}

model TableCharges {
  id           String     @id @default(auto()) @map("_id") @db.ObjectId
  eventTableId String     @db.ObjectId
  eventTable   EventTable @relation(fields: [eventTableId], references: [id])
  feeName      String
  // TODO: Should be Float — stored as String by Fiverr team. Fix during data migration.
  feeAmount    String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model ClubFavorite {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  clubId    String   @db.ObjectId
  club      User     @relation("club", fields: [clubId], references: [id])
  userId    String   @db.ObjectId
  user      User     @relation("user", fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EventFavorite {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  eventId   String   @db.ObjectId
  event     Events   @relation(fields: [eventId], references: [id])
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FavoritePost {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  postId    String   @db.ObjectId
  post      Post     @relation(fields: [postId], references: [id])
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Booking {
  id             String        @id @default(auto()) @map("_id") @db.ObjectId
  userId         String        @db.ObjectId
  user           User          @relation(fields: [userId], references: [id])
  bookingType    BookingType
  tableId        String?       @db.ObjectId
  table          EventTable?   @relation(fields: [tableId], references: [id])
  ticketId       String?       @db.ObjectId
  ticket         EventTickets? @relation(fields: [ticketId], references: [id])
  eventId        String        @db.ObjectId
  event          Events        @relation(fields: [eventId], references: [id])
  guest          Int
  status         BookingStatus @default(PENDING)
  numberOfFemale Int
  numberOfMale   Int
  paidAmount     Int
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model Chat {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  senderId   String   @db.ObjectId
  receiverId String   @db.ObjectId
  message    String
  roomId     String   @db.ObjectId
  images     String[]
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  sender     User     @relation("SenderRelation", fields: [senderId], references: [id])
  receiver   User     @relation("ReceiverRelation", fields: [receiverId], references: [id])
  room       Room     @relation(fields: [roomId], references: [id])

  @@map("chats")
}

model Room {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  senderId   String   @db.ObjectId
  receiverId String   @db.ObjectId
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  sender     User     @relation("SenderRelation", fields: [senderId], references: [id])
  receiver   User     @relation("ReceiverRelation", fields: [receiverId], references: [id])
  chat       Chat[]

  @@map("rooms")
}

model BlockUser {
  id        String @id @default(auto()) @map("_id") @db.ObjectId
  blockerId String @db.ObjectId
  blockedId String @db.ObjectId
  blocker   User   @relation("blocker", fields: [blockerId], references: [id])
  blocked   User   @relation("blocked", fields: [blockedId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt


  
}

enum VenueArea {
  CANGGU
  ULUWATU
  SEMINYAK
  UBUD
}

enum VenueCategory {
  BEACH_CLUB
  RESTAURANT
  NIGHTLIFE
  WELLNESS
  EVENTS
}

enum BookingProvider {
  BOOKETING        // Indonesian — possibly API-able
  MTIX             // Indonesian event ticketing — has API docs
  CROWDSTACK
  OPENTABLE        // Partnership-gated; URL only for now
  RESY             // Partnership-gated
  RESDIARY
  TOAST
  SEVENROOMS       // Partnership-gated
  CUSTOM_WEB       // Their own form / WordPress
  PHONE            // Call to book
  WHATSAPP
  INSTAGRAM_DM
  NONE             // Walk-in only
}

model Venue {
  id              String         @id @default(auto()) @map("_id") @db.ObjectId
  name            String
  slug            String         @unique
  description     String         @default("")
  editorial       String         @default("")
  area            VenueArea
  category        VenueCategory
  tags            String[]       @default([])
  address         String         @default("")
  latitude        Float?
  longitude       Float?
  phone           String         @default("")
  website         String         @default("")
  instagram       String         @default("")
  priceRange      Int            @default(2)
  openingHours    Json?
  weeklySchedule  Json?
  photos          String[]
  heroImage       String         @default("")
  // ── Booking integration ───────────────────────────────────────────
  // Tier 2 today (URL + provider metadata + per-day routing).
  // Tier 3 future (apiKey + externalVenueId enable native integration).
  bookingUrl              String           @default("")     // primary URL for online providers
  bookingProvider         BookingProvider?                  // which system the venue uses
  bookingPhone            String           @default("")     // for PHONE provider
  bookingWhatsapp         String           @default("")     // for WHATSAPP provider
  bookingInstagram        String           @default("")     // for INSTAGRAM_DM provider
  bookingDailyUrls        Json?                             // { mon: "...", tue: "...", ... }
  bookingExternalVenueId  String           @default("")     // for native API later
  bookingApiKeyEncrypted  String           @default("")     // for native API later (encrypted)
  // ──────────────────────────────────────────────────────────────────
  isActive        Boolean        @default(true)
  isFeatured      Boolean        @default(false)
  rating            Float          @default(0)
  googleRating      Float?
  googleRatingCount Int?
  ownerId           String         @db.ObjectId
  owner             User           @relation("VenueOwner", fields: [ownerId], references: [id])
  events            Events[]       @relation("VenueEvents")
  favorites         VenueFavorite[]
  ratings           VenueRating[]
  vibes             VenueVibe[]
  bookingClicks     VenueBookingClick[]
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@map("venues")
}

// Pink Pineapple booking attribution log. Every time a user taps the
// "Book" CTA on a venue card or detail screen, we log a row here so we
// can later prove "Pink Pineapple drove X bookings this month" to the
// venue. The redirect URL we send users to includes a pp_click_id query
// param matching this row's id, so if/when we wire native integrations
// we can correlate the click with the actual confirmed booking.
model VenueBookingClick {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  venueId     String   @db.ObjectId
  venue       Venue    @relation(fields: [venueId], references: [id])
  userId      String?  @db.ObjectId
  user        User?    @relation("UserBookingClicks", fields: [userId], references: [id])
  /// MOBILE_APP, DASHBOARD, WEB, etc — where the click originated.
  source      String   @default("MOBILE_APP")
  /// Provider the click was routed to (snapshotted from venue at click time).
  provider    String   @default("")
  /// The destination URL the user was sent to (with utm + pp_click_id appended).
  redirectUrl String   @default("")
  /// Coarse client device identifier — populated when available.
  deviceId    String   @default("")
  /// Filled in later if/when we get a confirmed booking back via native API.
  convertedAt DateTime?
  /// Native-integration booking ID from the third-party provider, if any.
  externalBookingId String @default("")
  createdAt   DateTime @default(now())

  @@index([venueId, createdAt])
  @@map("venue_booking_clicks")
}

model VenueFavorite {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  venueId   String   @db.ObjectId
  venue     Venue    @relation(fields: [venueId], references: [id])
  userId    String   @db.ObjectId
  user      User     @relation("VenueFavorites", fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("venue_favorites")
}

// Pink Pineapple user rating — one per (user, venue), upsertable.
model VenueRating {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  venueId   String   @db.ObjectId
  venue     Venue    @relation(fields: [venueId], references: [id])
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id])
  score     Int      // 1-5
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, venueId])
  @@index([venueId])
  @@map("venue_ratings")
}

// Pink Pineapple live vibe check — append-only, time-bounded.
// Aggregation queries should filter to recent (e.g. last 4 hours).
model VenueVibe {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  venueId   String   @db.ObjectId
  venue     Venue    @relation(fields: [venueId], references: [id])
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id])
  crowd     Int      // 0-4 (Empty → At capacity)
  music     Int      // 0-4 (No music → Incredible)
  energy    Int      // 0-4 (Dead → On fire)
  createdAt DateTime @default(now())

  @@index([venueId, createdAt])
  @@map("venue_vibes")
}

enum BookingType {
  TABLE
  TICKET
}

enum BookingStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum FollowerStatus {
  PENDING
  ACCEPTED
  BLOCKED
}

enum EventStatus {
  ONGOING
  UPCOMING
  APPROVED
  COMPLETED
  PENDING
  REJECTED
}

enum UserRole {
  ADMIN
  CLUB
  USER
}

enum UserStatus {
  ACTIVE
  PENDING
  INACTIVE
  BLOCKED
}

enum ProfilePrivacyStatus {
  VIEWABLE
  HIDDEN
}
